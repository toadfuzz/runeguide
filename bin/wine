#!/bin/sh
exec python3 - "$@" <<'PY'
import json
import os
import sys

args = sys.argv[1:]
exe = None
extra = []
i = 0
while i < len(args):
    arg = args[i]
    if arg == '--ia32':
        i += 1
        continue
    if arg == '--x64':
        i += 2
        continue
    if arg == '--args':
        if i + 1 >= len(args):
            raise SystemExit('wine wrapper: missing value for --args')
        extra.extend(json.loads(args[i + 1]))
        i += 2
        continue
    if exe is None:
        exe = arg
    else:
        extra.append(arg)
    i += 1

if exe is None:
    raise SystemExit('wine wrapper: missing executable')

os.execv('/usr/lib/wine/wine64', ['/usr/lib/wine/wine64', exe, *extra])
PY
